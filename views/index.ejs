<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Spotify Snapshots</title>

  <!-- Make sure your Express static points to "public" -->
  <link rel="stylesheet" href="/styles/main.css" />
</head>
<body>
  <%- include("partials/header") %>

  <main class="container">
    <section class="hero">
      <div class="hero-text">
        <h1>Spotify Wrapped Mini Edition</h1>
        <p class="subtitle">
          Connect your Spotify account to view your listening data over
          <strong>short-term</strong> and <strong>long-term</strong> periods, and share your thoughts to the community page.
        </p>

        <div class="cta-row">
          <a class="btn btn-primary" href="/auth/login">Connect Spotify</a>
          <a class="btn btn-secondary" href="/community">Post</a>
        </div>

        <ul class="feature-list">
          <li>Recently played + top tracks/artists</li>
          <li>Short-term vs long-term insights</li>
          <li>Share thoughts to the community</li>
        </ul>
      </div>
    </section>
  </main>

  <%- include("partials/footer") %>
</body>
</html>
