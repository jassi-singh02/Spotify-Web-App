<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Spotify Snapshot</title>
  <link rel="stylesheet" href="/Styles/Main.css" />
</head>

<body>
  <%- include("partials/header") %>

  <main class="container">

    <!-- User Profile Bar -->
    <div class="dash-profile">
      <% if (user.images && user.images.length > 0) { %>
        <img class="dash-avatar" src="<%= user.images[0].url %>" alt="<%= user.display_name %>" />
      <% } %>
      <div>
        <h2 class="dash-name"><%= user.display_name %></h2>
        <span class="dash-followers"><%= user.followers.total %> followers</span>
      </div>
      <div class="dash-actions">
        <a class="btn btn-primary" href="/community">Community Feed</a>
        <a class="btn btn-secondary" href="/">Home</a>
      </div>
    </div>

    <!-- 2×2 Grid -->
    <div class="dash-grid">

      <!-- Quadrant 1: Recently Played -->
      <div class="dash-card">
        <h3 class="dash-card-title">Recently Played</h3>
        <% if (recent.length > 0) { %>
          <ul class="dash-list">
            <% recent.forEach((item) => { %>
              <li class="dash-list-item">
                <span class="dash-item-name"><%= item.track.name %></span>
                <span class="dash-item-sub"><%= item.track.artists.map(a => a.name).join(', ') %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="dash-empty">No recently played tracks found.</p>
        <% } %>
      </div>

      <!-- Quadrant 2: Top Tracks -->
      <div class="dash-card">
        <h3 class="dash-card-title">Top Tracks <span class="dash-badge">Last 4 Weeks</span></h3>
        <% if (topTracks.length > 0) { %>
          <ul class="dash-list">
            <% topTracks.forEach((track, idx) => { %>
              <li class="dash-list-item">
                <span class="dash-rank"><%= idx + 1 %></span>
                <span class="dash-item-name"><%= track.name %></span>
                <span class="dash-item-sub"><%= track.artists.map(a => a.name).join(', ') %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="dash-empty">No top tracks found.</p>
        <% } %>
      </div>

      <!-- Quadrant 3: Top Artists -->
      <div class="dash-card">
        <h3 class="dash-card-title">Top Artists <span class="dash-badge">All Time</span></h3>
        <% if (topArtists.length > 0) { %>
          <ul class="dash-list">
            <% topArtists.forEach((artist, idx) => { %>
              <li class="dash-list-item dash-list-item--artist">
                <% if (artist.images && artist.images.length > 0) { %>
                  <img class="dash-artist-img" src="<%= artist.images[artist.images.length - 1].url %>" alt="<%= artist.name %>" />
                <% } %>
                <span class="dash-rank"><%= idx + 1 %></span>
                <span class="dash-item-name"><%= artist.name %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="dash-empty">No top artists found.</p>
        <% } %>
      </div>

      <!--Quadrant 4: 6 month Top Tracks -->
      <div class="dash-card">
        <h3 class="dash-card-title">Top Tracks <span class="dash-badge"> Last 6 Months </span></h3>
        <% if (topTracksMedium.length > 0) { %>
          <ul class="dash-list">
            <% topTracksMedium.forEach((track, idx) => { %>
              <li class="dash-list-item">
                <span class="dash-rank"><%= idx + 1 %></span>
                <span class="dash-item-name"><%= track.name %></span>
                <span class="dash-item-sub"><%= track.artists.map(a => a.name).join(', ') %></span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="dash-empty">No top tracks found.</p>
        <% } %>
      </div>

      <!-- Quadrant 5: Share Snapshot -->
      <div class="dash-card dash-card--share">
        <h3 class="dash-card-title">Share a Snapshot</h3>
        <p class="dash-share-desc">Post your listening data to the community feed.</p>
        <form action="/community" method="POST" class="dash-share-form">
          <input type="text" name="title" placeholder="Post title" required />
          <textarea name="body" placeholder="What are you listening to lately?" rows="4" required></textarea>
          <input type="text" name="author" placeholder="Your name (optional)" />
          <button type="submit" class="btn btn-primary">Share to Community</button>
        </form>
      </div>

    </div>
  </main>

  <%- include("partials/footer") %>
</body>

</html>
