<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard | Spotify Snapshot</title>

  <link rel="stylesheet" href="/Styles/Main.css" />
  <style>
    .dashboard-header {
      margin-bottom: 2rem;
      padding-bottom: 2rem;
      border-bottom: 2px solid #1DB954;
    }

    .user-info {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .user-info img {
      width: 60px;
      height: 60px;
      border-radius: 50%;
    }

    .user-info h2 {
      margin: 0;
      color: #1DB954;
    }

    .section {
      margin-bottom: 3rem;
    }

    .section h3 {
      color: #1DB954;
      margin-top: 0;
      border-bottom: 1px solid #ddd;
      padding-bottom: 0.5rem;
    }

    .item-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .item-list li {
      padding: 0.8rem;
      margin-bottom: 0.5rem;
      background-color: #f5f5f5;
      border-radius: 4px;
      line-height: 1.5;
    }

    .item-list li strong {
      color: #191414;
    }

    .item-list li .artist {
      color: #666;
      font-size: 0.9rem;
    }

    .nav-links {
      margin-top: 2rem;
      display: flex;
      gap: 1rem;
    }

    .btn {
      padding: 0.75rem 1.5rem;
      text-decoration: none;
      border-radius: 24px;
      font-weight: bold;
      cursor: pointer;
      border: none;
      display: inline-block;
      transition: all 0.3s ease;
    }

    .btn-primary {
      background-color: #1DB954;
      color: white;
    }

    .btn-primary:hover {
      background-color: #1ed760;
    }

    .btn-secondary {
      background-color: transparent;
      color: #1DB954;
      border: 2px solid #1DB954;
    }

    .btn-secondary:hover {
      background-color: #1DB954;
      color: white;
    }
  </style>
</head>
<body>
  <%- include("Partials/Header") %>

  <main class="container">
    <!-- User Profile Header -->
    <div class="dashboard-header">
      <div class="user-info">
        <% if (user.images && user.images.length > 0) { %>
          <img src="<%= user.images[0].url %>" alt="<%= user.display_name %>" />
        <% } %>
        <div>
          <h2><%= user.display_name %></h2>
          <p>Followers: <%= user.followers.total %></p>
        </div>
      </div>
    </div>

    <!-- Recently Played Section -->
    <section class="section">
      <h3>Recently Played (Last 10)</h3>
      <% if (recent.length > 0) { %>
        <ul class="item-list">
          <% recent.forEach((item) => { %>
            <li>
              <strong><%= item.track.name %></strong>
              <div class="artist">
                by <%= item.track.artists.map(a => a.name).join(', ') %>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p>No recently played tracks found.</p>
      <% } %>
    </section>

    <!-- Top Tracks (Short-term) Section -->
    <section class="section">
      <h3>Top Tracks (Short-term)</h3>
      <% if (topTracks.length > 0) { %>
        <ul class="item-list">
          <% topTracks.forEach((track, idx) => { %>
            <li>
              <strong><%= idx + 1 %>. <%= track.name %></strong>
              <div class="artist">
                by <%= track.artists.map(a => a.name).join(', ') %>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p>No top tracks found.</p>
      <% } %>
    </section>

    <!-- Top Artists (Long-term) Section -->
    <section class="section">
      <h3>Top Artists (Long-term)</h3>
      <% if (topArtists.length > 0) { %>
        <ul class="item-list">
          <% topArtists.forEach((artist, idx) => { %>
            <li>
              <strong><%= idx + 1 %>. <%= artist.name %></strong>
              <div class="artist">
                Followers: <%= artist.followers%>
              </div>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <p>No top artists found.</p>
      <% } %>
    </section>

    <!-- Navigation -->
    <div class="nav-links">
      <a class="btn btn-primary" href="/community">Community Feed</a>
      <a class="btn btn-secondary" href="/">Home</a>
    </div>
  </main>

  <%- include("Partials/Footer") %>
</body>
</html>
